  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:backend": "npm run dev:bunny-edge",
    "dev:bunny-edge": "sh -c 'fuser -k 8787/tcp >/dev/null 2>&1 || true; npx --yes deno run -A bunny-edge/api.ts'",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "build:bunny-edge": "node scripts/build-bunny-edge.mjs",
    "preview:ui": "vite preview",
    "dev": "concurrently -n backend,frontend -c cyan,green \"npm run dev:bunny-edge\" \"npm run dev:ui\"",
    "clean:wrangler": "rm -rf .wrangler",
    "bunny:upload": "node scripts/bunny-upload.mjs",
    "bunny:purge": "node scripts/bunny-purge.mjs",
    "deploy:ui": "npm run build:ui && npm run bunny:upload && npm run bunny:purge",
    "deploy": "npm run deploy:ui"
  },
  "repository": {
    "type": "git",
