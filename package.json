{
  "name": "file60",
  "version": "1.0.0",
  "description": "No-login file hosting with Bunny Edge + Backblaze B2",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,green \"npm run dev:backend\" \"npm run dev:ui\"",
    "dev:backend": "sh -c 'fuser -k 8787/tcp >/dev/null 2>&1 || true; npx --yes deno run -A --env bunny-edge/api.ts'",
    "dev:ui": "vite",
    "build:backend": "node scripts/build-bunny-edge.mjs",
    "build:ui": "vite build",
    "build": "npm run build:backend && npm run build:ui",
    "deploy:ui": "npm run build:ui && npm run bunny:upload && npm run bunny:purge",
    "bunny:upload": "node scripts/bunny-upload.mjs",
    "bunny:purge": "node scripts/bunny-purge.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoabhaysharma/file60.git"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@bunny.net/edgescript-sdk": "^0.12.1",
    "@bunny.net/storage-sdk": "^0.3.1",
    "@libsql/client": "^0.17.3",
    "aws4fetch": "^1.0.20",
    "codemirror": "^5.65.16",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
