# Local API: `npm run dev:bunny-edge` reads this file from disk (see loadDotEnvFilesIntoDenoEnv in bunny-edge/api.ts), then .dev.vars — no shell sourcing.
# API URL for backend API (local Bunny Edge runtime or deployed Bunny Edge URL)
VITE_API_URL=http://localhost:8787
VITE_TURNSTILE_SITE_KEY=

# Session Secret (Random string for signing JWTs)
JWT_SECRET=

# Max upload size in bytes (hard capped by server at 300MB)
MAX_FILE_SIZE=314572800


# Bunny Storage settings
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_REGION=Falkenstein
BUNNY_STORAGE_ENDPOINT=https://storage.bunnycdn.com

# Bunny Edge only: set to 1 to list /temp/ after each upload and fail if the object is missing (debugging)
VERIFY_STORAGE_LIST=

# CDN URL for public file links and redirects (Pull Zone). Default in code: https://cdn-file60.bythub.in
BUNNY_PUBLIC_URL=https://cdn-file60.bythub.in

# Optional override: if your account needs a specific access key id for S3-compatible API
BUNNY_STORAGE_ACCESS_KEY_ID=

# Bunny database (optional for local fallback, recommended for production metadata).
# In Bunny Edge, use Database → Access → "Add Secrets to Edge Script" so URL/token are injected correctly.
# URL form: libsql://[id].lite.bunnydb.net (full hostname; the API normalizes to https for the driver).
BUNNY_DATABASE_URL=
BUNNY_DATABASE_AUTH_TOKEN=

# Backend API runtime URL (when using Bunny Edge API, set this to your Edge Script URL)
# VITE_API_URL=

# Optional: Bunny API credentials for automated CDN purge
BUNNY_API_KEY=
BUNNY_PULL_ZONE_ID=

# Optional: disable API rate limiting (useful for local development only)
DISABLE_RATE_LIMIT=false

# Optional: local development Turnstile test secret
TURNSTILE_SECRET_KEY=
